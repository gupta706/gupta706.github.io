source "https://rubygems.org"

# Jekyll — the static-site generator. GitHub Pages / the Action build with this.
gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"      # RSS/Atom feed for the blog
  gem "jekyll-sitemap", "~> 1.4"    # sitemap.xml for search engines
  gem "jekyll-seo-tag", "~> 2.8"    # <meta> tags for SEO + social cards
end

# Needed to run `jekyll serve` on Ruby 3+.
gem "webrick", "~> 1.8"

# Faster file watching on macOS during local preview.
gem "jekyll-watch", "~> 2.2"
